# Copie este arquivo para .streamlit/secrets.toml e preencha com valores reais.
# secrets.toml NÃO vai pro Git (está no .gitignore) — cole o mesmo conteúdo na
# UI de "Secrets" do Streamlit Community Cloud quando fizer o deploy.

app_password = "escolha-uma-senha-aqui"

[postgres]
host = "db.xxxxxxxxxxxx.supabase.co"
port = 5432
dbname = "postgres"
user = "postgres"
password = "sua-senha-do-banco-no-supabase"
