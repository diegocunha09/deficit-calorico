# Copie este arquivo para .streamlit/secrets.toml e preencha com valores reais.
# secrets.toml NÃO vai pro Git (está no .gitignore) — cole o mesmo conteúdo na
# UI de "Secrets" do Streamlit Community Cloud quando fizer o deploy.
#
# Use a conexão "Session pooler" do Supabase (não "Direct connection"): a Direct
# connection resolve por IPv6 e trava com timeout em várias redes/hospedagens
# sem saída IPv6, incluindo o Streamlit Community Cloud. O Session pooler
# resolve por IPv4 e funciona em qualquer lugar. Pegue esses valores em
# "Connect" (no painel do projeto Supabase) → aba "Direct Connection" →
# seletor "Session pooler".

app_password = "escolha-uma-senha-aqui"

[postgres]
host = "aws-0-xx-xxxx-1.pooler.supabase.com"
port = 5432
dbname = "postgres"
user = "postgres.xxxxxxxxxxxxxxxxxxxx"
password = "sua-senha-do-banco-no-supabase"
